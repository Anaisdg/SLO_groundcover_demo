# =============================================================================
# SLO Remediation Agent — Environment Variables
# =============================================================================
# Copy this to .env and fill in your values.
# Usage: source .env && python agent/slo_agent.py
# =============================================================================

# --- AWS / Bedrock -----------------------------------------------------------
AWS_REGION=us-east-1
AWS_PROFILE=default
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0

# --- MCP Server Endpoints ---------------------------------------------------
GROUNDCOVER_MCP_URL=https://mcp.groundcover.com/api/mcp
LINEAR_MCP_URL=https://mcp.linear.app/sse

# --- Groundcover MCP Auth ---------------------------------------------------
# Find these on your Groundcover dashboard under MCP setup.
GROUNDCOVER_API_KEY=
GROUNDCOVER_TENANT_UUID=
GROUNDCOVER_BACKEND_ID=
GROUNDCOVER_TIMEZONE=America/Chicago

# Linear MCP auth — your Linear personal API key
# Generate at: https://linear.app/settings/api
LINEAR_API_KEY=

# --- Agent Config ------------------------------------------------------------
SLO_THRESHOLD_MS=500
TARGET_NAMESPACE=slo-demo

# --- EKS Deployment (used by deploy.sh) -------------------------------------
CLUSTER_NAME=slo-demo-cluster

# To run the agent *inside* EKS (so Groundcover captures pod logs), put the same
# values into a Kubernetes Secret — see README "Capturing agent logs in Groundcover".
