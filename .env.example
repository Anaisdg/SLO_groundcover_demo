# =============================================================================
# SLO Remediation Demo — Environment Variables
# =============================================================================
# Copy this to .env and fill in your values.
# =============================================================================

# --- Groundcover MCP Auth ---------------------------------------------------
# Find these on your Groundcover dashboard under MCP setup.
GROUNDCOVER_API_KEY=
GROUNDCOVER_MCP_URL=https://mcp.groundcover.com/api/mcp
GROUNDCOVER_TENANT_UUID=
GROUNDCOVER_BACKEND_ID=
GROUNDCOVER_TIMEZONE=America/Chicago

# --- Linear MCP Auth --------------------------------------------------------
# Generate at: https://linear.app/settings/api (must have full permissions)
LINEAR_API_KEY=

# --- OTEL Telemetry (optional) ----------------------------------------------
# For sending Claude Code telemetry to an OTEL backend (e.g. Groundcover).
# See .claude/settings.json.example for Claude Code-specific OTEL config.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# --- EKS Deployment (used by deploy.sh) -------------------------------------
CLUSTER_NAME=slo-demo-cluster
AWS_REGION=us-east-2
